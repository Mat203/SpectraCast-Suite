{
    "font.family": "monospace",
    "font.size": 11,
    "text.color": "#E0E0E0",
    "axes.facecolor": "#121212",
    "axes.edgecolor": "#444444",
    "axes.titlesize": 16,
    "axes.titleweight": "bold",
    "axes.titlecolor": "#FFFFFF",
